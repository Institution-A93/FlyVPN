# Скопировать в group_vars/control/vault.yml и зашифровать (ansible-vault encrypt ...).
# Реальный vault.yml — в .gitignore (group_vars/*/vault.yml).
cp_db_app_password: "CHANGE-ME-app"
cp_db_radius_password: "CHANGE-ME-radius"
# RADIUS-клиенты = ingress-узлы (появятся позже). На MMVP можно оставить пустым.
cp_radius_clients: []
